{
  "name": "altosybioagents",
  "version": "1.0.0",
  "private": true,
  "description": "altosybioagents desktop app — Electron shell with Python FastAPI sidecar",
  "main": "out/main/index.js",
  "author": "altosybioagents",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "ts-prune": "node dev/run-ts-prune.cjs",
    "bundle-size": "node dev/check-bundle-size.cjs",
    "test:frontend": "vitest run",
    "test:backend": "cd backend && python -m pytest tests/ -q",
    "dist": "npm run build && electron-builder --win",
    "dist:test": "npm run build && electron-builder --win --dir"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@tanstack/react-query": "^5.100.11",
    "electron-updater": "^6.3.9",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.45",
    "mermaid": "^11.14.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-window": "^1.8.11",
    "recharts": "^2.15.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^42.1.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "jsdom": "^25.0.0",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "ts-prune": "^0.10.3",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
